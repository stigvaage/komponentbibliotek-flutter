{
  "name": "@stigvaage/designsystemet-flutter-mcp",
  "version": "0.2.0",
  "description": "MCP-server for designsystemet-flutter — komponent-API, migrering og dokumentasjonssøk",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "designsystemet-flutter-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp -r src/data dist/",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build-data": "tsx scripts/build-data.ts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "designsystemet",
    "flutter",
    "ai",
    "claude-code",
    "cursor"
  ],
  "author": "Stig H. Våge",
  "repository": {
    "type": "git",
    "url": "https://github.com/stigvaage/designsystemet-flutter.git",
    "directory": "mcp-server"
  },
  "homepage": "https://stigvaage.github.io/designsystemet-flutter/",
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "minisearch": "^7.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.0"
  }
}
